NODE_ENV=development
PORT=3000
API_PREFIX=api

DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/vista_db?schema=public"

JWT_ACCESS_SECRET=vista-access-secret-key-2026-change-in-production
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=vista-refresh-secret-key-2026-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_ME_EXPIRES_IN=30d

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict