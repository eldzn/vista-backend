generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  nickname         String    @unique
  email            String    @unique
  backupEmail      String?   @unique @map("backup_email")
  passwordHash     String
  about            String?
  birthDate        String?   @map("birth_date")
  passwordChangeAt DateTime? @default(now()) @map("password_change_at")
  avatarFileName   String?   @map("avatar_file_name")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  videos           Video[]
}

model Video {
  id           String     @id @default(uuid())
  fileName     String     @map("file_name")
  originalName String     @map("original_name")
  mimetype     String
  size         Int
  title        String
  description  String?
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  author       User       @relation(fields: [userId], references: [id])
  userId       String
  category     Category?  @relation(fields: [categoryId], references: [id])
  categoryId   String?
  ageRating    AgeRating? @relation(fields: [ageRatingId], references: [id])
  ageRatingId  String?
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  videos    Video[]
  createdAt DateTime @default(now()) @map("created_at")
}

model AgeRating {
  id        String   @id @default(uuid())
  code      String   @unique
  videos    Video[]
  createdAt DateTime @default(now()) @map("created_at")
}
