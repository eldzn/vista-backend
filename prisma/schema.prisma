generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String      @id @default(uuid())
  nickname           String      @unique
  email              String      @unique
  backupEmail        String?     @unique @map("backup_email")
  passwordHash       String
  about              String?
  birthDate          String?     @map("birth_date")
  passwordChangeAt   DateTime?   @default(now()) @map("password_change_at")
  avatarFileName     String?     @map("avatar_file_name")
  avatarUrl          String?     @map("avatar_url")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  videos             Video[]
  favoriteVideos     Video[]     @relation("FavoriteVideos")
  likesVideo         Video[]     @relation("LikesVideo")
  comments           Comment[]
  following          User[]      @relation("UserFollowing")
  followers          User[]      @relation("UserFollowing")
  playlist           PlayList[]
  reportedComplaints Complaint[] @relation("ReporterComplaints")
  reviewedComplaints Complaint[] @relation("ModeratorComplaints")

  @@index([nickname])
}

model Video {
  id             String          @id @default(uuid())
  originalName   String          @map("original_name")
  url            String
  name           String
  thumbnailUrl   String?         @map("thumbnail_url")
  mimetype       String
  size           Int
  title          String
  description    String?
  isPublic       Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  author         User            @relation(fields: [userId], references: [id])
  userId         String
  category       Category?       @relation(fields: [categoryId], references: [id])
  categoryId     String?
  ageRating      AgeRating?      @relation(fields: [ageRatingId], references: [id])
  ageRatingId    String?
  tags           Tag[]           @relation("VideoTags")
  favoritedBy    User[]          @relation("FavoriteVideos")
  likedBy        User[]          @relation("LikesVideo")
  views          Int             @default(0)
  comments       Comment[]
  complaints     Complaint[]     @relation("VideoComplaints")
  playlistVideos PlayListVideo[]
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  videos    Video[]  @relation("VideoTags")
  createdAt DateTime @default(now()) @map("created_at")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  videos    Video[]
  createdAt DateTime @default(now()) @map("created_at")
}

model AgeRating {
  id        String   @id @default(uuid())
  code      String   @unique
  videos    Video[]
  createdAt DateTime @default(now()) @map("created_at")
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId   String

  @@index([videoId])
  @@index([userId])
}

model PlayList {
  id             String          @id @default(uuid())
  title          String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @map("updated_at")
  user           User?           @relation(fields: [userId], references: [id])
  userId         String
  playListVideos PlayListVideo[]
}

model PlayListVideo {
  id         String   @id @default(uuid())
  playlistId String
  videoId    String
  addedAt    DateTime @default(now()) @map("added_at")
  playlist   PlayList @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([playlistId, videoId])
  @@index([playlistId])
  @@index([videoId])
}

model Complaint {
  id           String          @id @default(uuid())
  reporter     User            @relation("ReporterComplaints", fields: [reporterId], references: [id])
  reporterId   String          @map("reporter_id")
  video        Video           @relation("VideoComplaints", fields: [videoId], references: [id])
  videoId      String          @map("video_id")
  reason       String
  blockReason  String?
  status       ComplaintStatus @relation("ComplaintStatusComplaints", fields: [statusId], references: [id])
  statusId     String          @map("status_id")
  reviewedBy   User?           @relation("ModeratorComplaints", fields: [reviewedById], references: [id])
  reviewedById String?         @map("reviewed_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  reviewedAt   DateTime?       @map("reviewed_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
}

model ComplaintStatus {
  id         String      @id @default(uuid())
  code       String      @unique
  name       String
  complaints Complaint[] @relation("ComplaintStatusComplaints")
}
